{
  "manifest_version": 3,
  "name": "TaskMaster",
  "version": "3.0.0",
  "description": "智能待办事项管理扩展",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
